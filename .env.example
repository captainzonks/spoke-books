# ==============================================================================
# SPOKE-BOOKS - MODULE ENVIRONMENT EXAMPLE
# ==============================================================================
# Description: Module-specific environment defaults for spoke-books
# Author: Matt Barham
# Created: 2026-03-15
# Modified: 2026-03-15
# Version: 1.0.0
# Host: Rome (Arch Linux / AMD Ryzen 5600x / Intel Arc A380)
# ==============================================================================
# Type: Template
# Security Level: LOW - Public image versions and non-sensitive defaults
# Component: module: books
# ==============================================================================

#### IMAGES

AUDIOBOOKSHELF_IMAGE=ghcr.io/advplyr/audiobookshelf:2.33.0
CALIBRE_IMAGE=lscr.io/linuxserver/calibre:9.5.0
GRAPHICAUDIO_IMAGE=spoke-books/graphicaudio:latest

#### NETWORK

AUDIOBOOKSHELF_IP=192.168.35.89
AUDIOBOOKSHELF_PORT=13378

CALIBRE_IP=192.168.35.90
CALIBRE_PORT=8080

GRAPHICAUDIO_IP=192.168.35.91
GRAPHICAUDIO_PORT=8093
# Set a secret key to protect the /refresh endpoint
GRAPHICAUDIO_REFRESH_KEY=changeme
# Audiobookshelf API key for cover art fetching (leave 'abs' if ABS auth is disabled)
GRAPHICAUDIO_ABS_KEY=abs

#### DATA PATHS (adjust to your media locations)

MEDIA_DIR=/mnt/media
# Shared library: audiobooks + ebooks together; ABS reads :ro, Calibre reads/writes :rw
# Calibre library (metadata.db) is stored in appdata (/config/), not here
AUDIOBOOKS_DIR=${MEDIA_DIR}/books
PODCASTS_DIR=${MEDIA_DIR}/podcasts
